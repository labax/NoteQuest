{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@notequest/application": ["./packages/application/src/index.ts"],
      "@notequest/content": ["./packages/content/src/index.ts"],
      "@notequest/domain": ["./packages/domain/src/index.ts"],
      "@notequest/infrastructure": ["./packages/infrastructure/src/index.ts"],
      "@notequest/test-support": ["./packages/test-support/src/index.ts"],
      "@notequest/ui": ["./packages/ui/src/index.ts"],
      "@notequest/web": ["./apps/web/src/architecture.ts"]
    },
    "allowImportingTsExtensions": true
  }
}
